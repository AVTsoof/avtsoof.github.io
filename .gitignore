# MkDocs build output (Do NOT commit; CI builds and deploys)
/site/

# Root datastore - raw/large datasets stay out of git (keep folder + docs)
/data/*
!/data/.gitkeep
!/data/README.md

# Python & Jupyter
__pycache__/
*.pyc
.ipynb_checkpoints/
*.egg-info/

# Virtual Environments
.env
.venv/
venv/
env/

# IDE settings (VS Code, JetBrains)
.vscode/
.idea/

# OS specific
.DS_Store
Thumbs.db

# Sensitive Data (Crucial for security!)
*.env
secret.json
credentials.py